# Local environment settings for Theme Vault Designer
# Copy this file to .env.local and update the values before running the server.

# Shopify storefront (no protocol, e.g. holidayprint.myshopify.com)
SHOPIFY_STORE_DOMAIN=

# Storefront API access token (Sales Channel > Apps > Develop apps > Storefront API)
SHOPIFY_STOREFRONT_TOKEN=

# Optional: override Shopify API version used for cart GraphQL operations
SHOPIFY_API_VERSION=2024-01

# Optional: network binding for the Express server
HOST=0.0.0.0
PORT=3000
